# Spark Configuration
SPARK_MASTER=local[*]
SPARK_MEMORY=4g

# Streaming Configuration
KAFKA_BROKER=localhost:9094
KAFKA_TOPIC=market_events
KAFKA_GROUP_ID=streaming-hot-path
AUTO_OFFSET_RESET=latest

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

REDIS_OHLC_PREFIX=hotpath:ohlc:1m
REDIS_ALERT_LIST_KEY=hotpath:alerts
REDIS_ALERT_CHANNEL=hotpath:alerts:channel
REDIS_HISTORY_LIMIT=120
ALERT_MOVE_PCT=0.5
SYMBOLS=

# Application
LOG_LEVEL=WARN
APP_NAME=CryptoStreamingApp


