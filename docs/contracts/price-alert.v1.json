{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://crypto-data-analytics-system.local/contracts/price-alert/v1",
  "title": "PriceAlertV1",
  "description": "Canonical price alert emitted by the hot path when a 1m candle crosses the configured move threshold.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "type",
    "alert_type",
    "severity",
    "exchange",
    "symbol",
    "interval",
    "bucket_start",
    "bucket_end",
    "open",
    "close",
    "change_abs",
    "change_pct",
    "direction",
    "threshold_pct",
    "trade_count",
    "source",
    "message",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Contract version used by all modules."
    },
    "type": {
      "type": "string",
      "const": "price_alert",
      "description": "Event family for alert messages."
    },
    "alert_type": {
      "type": "string",
      "enum": ["price_move"],
      "description": "Specific alert category."
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warning", "critical"],
      "description": "Operational severity level."
    },
    "exchange": {
      "type": "string",
      "enum": ["binance"],
      "description": "Source exchange name."
    },
    "symbol": {
      "type": "string",
      "pattern": "^[A-Z0-9]{5,20}$",
      "description": "Trading pair symbol, for example BTCUSDT."
    },
    "interval": {
      "type": "string",
      "enum": ["1m"],
      "description": "Candle interval covered by the alert."
    },
    "bucket_start": {
      "type": "integer",
      "minimum": 0,
      "description": "Candle window start timestamp in epoch milliseconds."
    },
    "bucket_end": {
      "type": "integer",
      "minimum": 0,
      "description": "Candle window end timestamp in epoch milliseconds."
    },
    "open": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]+)?$",
      "description": "Opening price encoded as decimal string."
    },
    "close": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]+)?$",
      "description": "Closing price encoded as decimal string."
    },
    "change_abs": {
      "type": "string",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$",
      "description": "Absolute change between close and open encoded as decimal string."
    },
    "change_pct": {
      "type": "string",
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$",
      "description": "Percentage change between close and open encoded as decimal string."
    },
    "direction": {
      "type": "string",
      "enum": ["up", "down", "flat"],
      "description": "Direction of the candle move."
    },
    "threshold_pct": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]+)?$",
      "description": "Configured alert threshold in percent encoded as decimal string."
    },
    "trade_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of trades aggregated into the candle."
    },
    "source": {
      "type": "string",
      "enum": ["stream_price_alert_1m"],
      "description": "Ingestion source channel."
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable alert message."
    },
    "created_at": {
      "type": "integer",
      "minimum": 0,
      "description": "Alert creation timestamp in epoch milliseconds."
    }
  }
}